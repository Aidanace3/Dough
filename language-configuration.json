{
  "comments": {
    "lineComment": "//",
    "blockComment": ["/(", ")\\"]
  },
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([@*]?[A-Za-z_][A-Za-z0-9_]*)",
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["(*", ")"]
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""]
  ]
}

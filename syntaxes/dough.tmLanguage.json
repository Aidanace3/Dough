{
  "scopeName": "source.doe",
  "name": "Doe Language",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.doe",
          "begin": "//",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.doe" } },
          "end": "$"
        },
        {
          "name": "comment.block.doe",
          "begin": "/\\(",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.begin.doe" } },
          "end": "\\)\\\\",
          "endCaptures": { "0": { "name": "punctuation.definition.comment.end.doe" } }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.doe",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.doe", "match": "\\\\." }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.float.doe", "match": "\\b\\d+\\.\\d+\\b" },
        { "name": "constant.numeric.integer.doe", "match": "\\b\\d+\\b" }
      ]
    },
    "keywords": {
      "patterns": [
        { "name": "keyword.control.doe", "match": "\\b(if|else|otherwise|ifcase|case|default|break|then|end|def|import)\\b" },
        { "name": "constant.language.null.doe", "match": "\\bnull\\b" }
      ]
    },
    "types": {
      "patterns": [
        { "name": "storage.type.doe", "match": "\\b(nopoly|const|str|string|int|flt|arr)\\b" }
      ]
    },
    "functions": {
      "patterns": [
        { "name": "support.function.builtin.doe", "match": "\\b(Print|Input|readln)\\b" }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.doe", "match": "(::|=>|<=|>=|&&|!\\||!&|\\*\\||\\.\\.|[=<>+\\-*/%|!&])" }
      ]
    }
  }
}

{
  "scopeName": "source.dough",
  "name": "Dough Language",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#points" },
    { "include": "#booleans" },
    { "include": "#numbers" },
    { "include": "#specialVariables" },
    { "include": "#deprecated" },
    { "include": "#declarations" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#calls" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.dough",
          "begin": "//",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.dough" }
          },
          "end": "$"
        },
        {
          "name": "comment.block.dough",
          "begin": "/\\(",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.begin.dough" }
          },
          "end": "\\)\\\\",
          "endCaptures": {
            "0": { "name": "punctuation.definition.comment.end.dough" }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.dough",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.dough", "match": "\\\\." }
          ]
        }
      ]
    },
    "points": {
      "patterns": [
        {
          "name": "entity.name.label.point.declaration.dough",
          "match": "\\(\\*[A-Za-z_][A-Za-z0-9_]*:?\\)"
        },
        {
          "name": "variable.parameter.pointref.dough",
          "match": "\\*[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.dough",
          "match": "@(?:true|false)\\b"
        },
        {
          "name": "constant.language.null.dough",
          "match": "(?i:\\bnull\\b)"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.dough",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.dough",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "specialVariables": {
      "patterns": [
        {
          "name": "variable.language.this.dough",
          "match": "(?i:\\bthis\\b)"
        }
      ]
    },
    "deprecated": {
      "patterns": [
        {
          "name": "invalid.deprecated.dough",
          "match": "(?i:\\b(?:def|funcs?)\\b)"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.function.definition.dough",
          "match": "(?i:\\b(def)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b)",
          "captures": {
            "1": { "name": "invalid.deprecated.dough" },
            "2": { "name": "entity.name.function.dough" }
          }
        },
        {
          "name": "meta.point.definition.dough",
          "match": "(\\(\\*)([A-Za-z_][A-Za-z0-9_]*)(:?\\))",
          "captures": {
            "2": { "name": "entity.name.label.point.declaration.dough" }
          }
        },
        {
          "name": "meta.dict.definition.dough",
          "match": "(?i:\\b(?:locked\\s+)?dict\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*:)",
          "captures": {
            "1": { "name": "entity.name.type.dough" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.dough",
          "match": "(?i:\\b(?:if|unless|elif|else|otherwise|ifcase|case|default|outlier|is|x|break|then|end|def|import|with|new|awaitval|return|yield|yeild|dict|locked|conf|as|each|in|do|loop|asa|enum|map|fluc)\\b)"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.dough",
          "match": "(?i:\\b(?:nopoly|const|str|string|int|flt|arr|dict|locked)\\b)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "support.function.builtin.dough",
          "match": "(?i:\\b(?:Print|Input|readln|Max|Min|map|exit|Store|request|debug|breakpoint)\\b)"
        }
      ]
    },
    "calls": {
      "patterns": [
        {
          "name": "entity.name.function.call.dough",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.dough",
          "match": "(>>|<<|::|===|==|=>|<=|>=|\\*\\*|%%|&&|!\\||!&|\\*\\||\\.\\.|[=<>+\\-*/%^|!&?])"
        }
      ]
    }
  }
}
